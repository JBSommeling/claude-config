{
  "skipWorkflowUsageWarning": true,
  "permissions": {
    "allow": [
      "Bash(git diff *)",
      "Bash(git log *)",
      "Bash(git branch *)",
      "Bash(git show *)"
    ]
  },
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Edit|Write|MultiEdit|NotebookEdit",
        "hooks": [
          {
            "type": "command",
            "command": "$HOME/.claude/hooks/enforce-delegation.sh"
          }
        ]
      },
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "$HOME/.claude/hooks/block-push-to-default-branch.sh"
          },
          {
            "type": "command",
            "command": "$HOME/.claude/hooks/enforce-delegation.sh"
          }
        ]
      }
    ]
  }
}
